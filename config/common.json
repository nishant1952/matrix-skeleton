{
  "accountId": "123456789012",
  "region": "ap-south-1",
  "organizationName": "my-org",
  "githubConnection": "arn:aws:codeconnections:ap-south-1:123456789012:connection/REPLACE-WITH-YOUR-CONNECTION-ID",
  "vpcCidr": "10.0.0.0/16",
  "enableVpcEndpoints": true,
  "hostedZone": {
    "id": "REPLACE_WITH_HOSTED_ZONE_ID",
    "name": "example.com"
  },
  "tags": {
    "ManagedBy": "CDK",
    "Organization": "my-org",
    "CostCenter": "Engineering"
  },
  "monitoring": {
    "alarmEmail": "alerts@example.com",
    "natGateway": {
      "dailyBytesThresholdGB": 5
    },
    "cloudwatchLogs": {
      "dailyBytesThresholdMB": 500
    },
    "codeBuild": {
      "buildDurationThresholdMinutes": 15,
      "dailyFailedBuildsThreshold": 5
    },
    "ecsTaskChurn": {
      "runningTaskCountZeroPeriods": 2
    },
    "ecsAutoScaling": {
      "maxCapacitySustainedMinutes": 30
    },
    "elastiCache": {
      "memoryThresholdPercent": 80,
      "cpuThresholdPercent": 70,
      "clusterName": "example-app-staging-redis"
    },
    "alb": {
      "consumedLcuThreshold": 10
    },
    "budget": {
      "monthlyLimitUSD": 500,
      "alertThresholds": [80, 100, 120]
    }
  }
}
